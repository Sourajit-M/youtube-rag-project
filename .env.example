# LLM Provider — switch between groq, gemini, openai
LLM_PROVIDER=groq
LLM_FALLBACK_PROVIDER=gemini

# API Keys
GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here

# YouTube
YOUTUBE_API_KEY=your_youtube_key_here

# Chunking — you'll understand why these numbers matter after Week 3
CHUNK_SIZE=300
CHUNK_OVERLAP=50

# Retrieval
TOP_K_RESULTS=5

# Database paths
CHROMA_DB_PATH=./data/vectordb
SQLITE_DB_PATH=./data/metadata.db
BM25_INDEX_PATH=./data/bm25_index.pkl

# Scheduler — how often to check for new videos (in minutes)
INGEST_INTERVAL_MINUTES=60